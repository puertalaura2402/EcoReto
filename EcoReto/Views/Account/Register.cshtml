@model EcoReto.Models.Usuario
@{
    ViewBag.Title = "Registro - EcoReto";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card mx-auto mt-5 eco-card" style="max-width: 480px;">
    <div class="text-center mb-3">
        <i class="bi bi-recycle" style="font-size: 3rem; color: #388e3c;"></i>
        <h2 class="mt-2">Crea tu cuenta en <span style="color:#2e7d32;">EcoReto</span></h2>
        <p class="text-muted">Únete al cambio por un futuro sostenible 🌿</p>
    </div>

    @using (Html.BeginForm("Register", "Account", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <div class="form-group mb-3">
            @Html.LabelFor(m => m.Nombre)
            @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control", placeholder = "Nombre" })
            @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger" })
        </div>

        <div class="form-group mb-3">
            @Html.LabelFor(m => m.Apellido)
            @Html.TextBoxFor(m => m.Apellido, new { @class = "form-control", placeholder = "Apellido" })
            @Html.ValidationMessageFor(m => m.Apellido, "", new { @class = "text-danger" })
        </div>

        <div class="form-group mb-3">
            @Html.LabelFor(m => m.UsuarioNombre)
            @Html.TextBoxFor(m => m.UsuarioNombre, new { @class = "form-control", placeholder = "Nombre de usuario" })
            @Html.ValidationMessageFor(m => m.UsuarioNombre, "", new { @class = "text-danger" })
        </div>

        <div class="form-group mb-3">
            @Html.LabelFor(m => m.Email)
            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Correo electrónico" })
            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
        </div>

        <div class="form-group mb-3">
            @Html.LabelFor(m => m.Contraseña)
            <div class="input-group">
                @Html.PasswordFor(m => m.Contraseña, new { @class = "form-control", placeholder = "Contraseña" })
                <button class="btn btn-outline-secondary" type="button" id="togglePasswordRegister">
                    <i class="bi bi-eye" id="eyeIconRegister"></i>
                </button>
            </div>
            @Html.ValidationMessageFor(m => m.Contraseña, "", new { @class = "text-danger" })
        </div>

        <div class="form-group mb-3">
            @Html.LabelFor(m => m.Telefono)
            @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control", placeholder = "Teléfono (opcional)" })
            @Html.ValidationMessageFor(m => m.Telefono, "", new { @class = "text-danger" })
        </div>

        <button type="submit" class="btn w-100 eco-btn">Crear Cuenta</button>

        if (TempData["MensajeExito"] != null)
        {
            <div class="alert alert-success text-center" style="border-radius: 10px; margin-bottom: 15px;">
                @TempData["MensajeExito"]
            </div>
        }


        if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center mt-3">@ViewBag.Error</div>
        }
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#togglePasswordRegister').click(function() {
                var passwordField = $(this).closest('.input-group').find('input[type="password"], input[type="text"]');
                var eyeIcon = $('#eyeIconRegister');

                if (passwordField.attr('type') === 'password') {
                    passwordField.attr('type', 'text');
                    eyeIcon.removeClass('bi-eye').addClass('bi-eye-slash');
                } else {
                    passwordField.attr('type', 'password');
                    eyeIcon.removeClass('bi-eye-slash').addClass('bi-eye');
                }
            });
        });
    </script>
}
