@model Dictionary<string, List<EcoReto.Models.Insignia>>
@{
    ViewBag.Title = "Insignias";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

<div class="container mt-5">
    <h2 class="text-center mb-4">🏅 Mis Insignias</h2>

    <style>
        .badges-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2rem;
            margin-top: 1.5rem;
            justify-items: center;
        }

        .badge-card {
            width: 320px;
            height: 480px;
            background: white;
            border-radius: 15px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: 0.3s ease;
            position: relative;
        }

            .badge-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 12px 30px rgba(0,0,0,0.15);
            }

            .badge-card.desbloqueada {
                border: 3px solid #4caf50;
            }

            .badge-card.bloqueada {
                opacity: 0.5;
                filter: grayscale(100%);
            }

        .badge-image {
            height: 260px;
            width: 100%;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #f6fdf7;
            position: relative;
        }

            .badge-image img {
                width: 100%;
                height: 100%;
                object-fit: contain;
                padding: 10px;
            }

        .badge-card.bloqueada .badge-image img {
            filter: grayscale(100%) brightness(0.7);
        }

        .badge-info {
            padding: 1rem;
            text-align: center;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

            .badge-info h5 {
                font-weight: 700;
                margin-bottom: 0.5rem;
                color: #1b5e20;
            }

        .badge-card.bloqueada .badge-info h5 {
            color: #757575;
        }

        .badge-info p {
            font-size: 0.9rem;
            color: #666;
            margin-bottom: 0.5rem;
            flex-grow: 1;
        }

        .badge-progress {
            margin-top: auto;
            padding-top: 0.75rem;
        }

        .progress-container {
            background: #e0e0e0;
            border-radius: 10px;
            height: 25px;
            overflow: hidden;
            margin-bottom: 0.5rem;
            position: relative;
        }

        .progress-bar {
            background: linear-gradient(90deg, #4caf50, #81c784);
            height: 100%;
            border-radius: 10px;
            transition: width 0.5s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 0.75rem;
            font-weight: bold;
        }

        .progress-text {
            font-size: 0.85rem;
            color: #1b5e20;
            font-weight: 600;
        }

        .badge-card.bloqueada .progress-text {
            color: #757575;
        }

        .badge-status {
            position: absolute;
            top: 10px;
            right: 10px;
            background: rgba(0,0,0,0.7);
            color: white;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: bold;
            z-index: 10;
        }

            .badge-status.desbloqueada {
                background: #4caf50;
            }

            .badge-status.bloqueada {
                background: #9e9e9e;
            }

        .section-title {
            margin-top: 50px;
            font-size: 1.6rem;
            font-weight: bold;
            color: #1b5e20;
            margin-bottom: 1rem;
        }

        .no-insignias {
            text-align: center;
            padding: 3rem;
            color: #757575;
        }
    </style>

    @if (Model == null || Model.Count == 0)
    {
        <div class="no-insignias">
            <h4>No hay insignias disponibles</h4>
        </div>
    }
    else
    {
        foreach (var categoria in Model)
        {
            var nombreCategoria = categoria.Key;
            var emoji = "";

            switch (nombreCategoria.ToLower())
            {
                case "generales":
                    emoji = "⭐";
                    break;
                case "reciclaje":
                    emoji = "♻️";
                    break;
                case "ahorro de energía":
                    emoji = "💡";
                    break;
                case "ahorro de agua":
                    emoji = "💧";
                    break;
                case "transporte sostenible":
                    emoji = "🚲";
                    break;
                case "estilo de vida verde":
                    emoji = "🌿";
                    break;
            }

            <h3 class="section-title">@emoji @nombreCategoria</h3>
            <div class="badges-grid">
                @foreach (var insignia in categoria.Value)
                {
                    var estado = insignia.EstaDesbloqueada ? "desbloqueada" : "bloqueada";
                    <div class="badge-card @estado">
                        <div class="badge-status @estado">
                            @if (insignia.EstaDesbloqueada)
                            {
                                <span>✓ Desbloqueada</span>
                            }
                            else
                            {
                                <span>🔒 Bloqueada</span>
                            }
                        </div>
                        <div class="badge-image">
                            <img src="@insignia.ImagenPath" alt="@insignia.Nombre" />
                        </div>
                        <div class="badge-info">
                            <h5>@insignia.Nombre</h5>
                            <p>@insignia.Descripcion</p>
                            <div class="badge-progress">
                                <div class="progress-container">
                                    <div class="progress-bar" style="width: @insignia.PorcentajeProgreso%">
                                        @if (insignia.PorcentajeProgreso > 20)
                                        {
                                            <span>@insignia.ProgresoActual/@insignia.ProgresoTotal</span>
                                        }
                                    </div>
                                </div>
                                <div class="progress-text">
                                    Progreso: @insignia.ProgresoActual/@insignia.ProgresoTotal
                                    @if (insignia.TipoRequisito == "MisionesPorCategoria")
                                    {
                                        <span>misiones</span>
                                    }
                                    else if (insignia.TipoRequisito == "MisionesTotales")
                                    {
                                        <span>misiones totales</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>
<br /><br />
<a href="@Url.Action("Index", "Perfil")" class="btn btn-primary">Ir al inicio</a>
