@model EcoReto.Models.Mision
@{
    ViewBag.Title = "Eliminar Misión";
}

<h2 class="text-center mb-4 text-danger">🗑️ Eliminar Misión</h2>

<div class="card p-4 shadow-sm mx-auto text-center" style="max-width: 600px;">
    <h4>¿Estás seguro que deseas eliminar la misión <strong>@Model.Titulo</strong>?</h4>
    <p class="text-muted mt-2">Esta acción no se puede deshacer.</p>

    @using (Html.BeginForm("EliminarConfirmado", "Misiones", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.IdMision)

        <button type="submit" class="btn btn-danger mt-3 w-100">Sí, eliminar</button>
        <a href="@Url.Action("Index", "Misiones")" class="btn btn-secondary w-100 mt-2">Cancelar</a>
    }
</div>
