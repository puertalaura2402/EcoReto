@model IEnumerable<EcoReto.Models.Mision>
@{
    ViewBag.Title = "Gestión de Misiones";
}

<h2 class="text-center mb-4">🌿 Gestión de Misiones Ambientales</h2>


@if (TempData["MensajeExito"] != null)
{
    <div class="alert alert-success text-center">@TempData["MensajeExito"]</div>
}
@if (TempData["MensajeError"] != null)
{
    <div class="alert alert-danger text-center">@TempData["MensajeError"]</div>
}


<div class="d-flex justify-content-between align-items-center mb-3">
    <a href="@Url.Action("Crear", "Misiones")" class="btn btn-primary">➕ Nueva Misión</a>

    @using (Html.BeginForm("Index", "Misiones", FormMethod.Get))
    {
        <div class="d-flex">
            @Html.DropDownList("idCategoria", (SelectList)ViewBag.Categorias, "Todas las categorías", new { @class = "form-select me-2" })
            <button type="submit" class="btn btn-success">🔍 Filtrar</button>
        </div>
    }
</div>

<table class="table table-striped table-bordered text-center align-middle">
    <thead class="table-success">
        <tr>
            <th>Título</th>
            <th>Descripción</th>
            <th>Puntos</th>
            <th>Categoría</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var m in Model)
        {
            <tr>
                <td>@m.Titulo</td>
                <td>@m.Descripcion</td>
                <td>@m.Puntos</td>
                <td>@m.CategoriaNombre</td>
                <td>
                    <a href="@Url.Action("Editar", new { id = m.IdMision })" class="btn btn-outline-success btn-sm">✏️ Editar</a>
                    <a href="@Url.Action("Eliminar", new { id = m.IdMision })" class="btn btn-outline-danger btn-sm">🗑️ Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
<br />
<a href="@Url.Action("PanelAdmin", "Admin")" class="btn btn-primary">Ir al inicio</a>
