@model EcoReto.Models.Usuario
@{
    ViewBag.Title = "Actividad del Usuario";
}

<h2 class="text-center mb-4">📊 Actividad de @Model.UsuarioNombre</h2>

<div class="card p-3 shadow-sm mb-4 text-center" style="max-width: 500px; margin: auto;">
    <h5><strong>Puntaje Total:</strong> @Model.PuntosTotales puntos</h5>
    <h6><strong>Misiones Completadas:</strong> @Model.MisionesCompletadas.Count</h6>
</div>

<p class="text-center text-muted">Correo: @Model.Email | Rol: @Model.Rol</p>

@if (Model.MisionesCompletadas == null || Model.MisionesCompletadas.Count == 0)
{
    <div class="alert alert-warning text-center">
        Este usuario aún no ha completado ninguna misión 🌱
    </div>
}
else
{
    <table class="table table-striped table-bordered text-center">
        <thead class="table-success">
            <tr>
                <th>Título</th>
                <th>Descripción</th>
                <th>Categoría</th>
                <th>Puntos</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in Model.MisionesCompletadas)
            {
                <tr>
                    <td>@m.Titulo</td>
                    <td>@m.Descripcion</td>
                    <td>@m.CategoriaNombre</td>
                    <td>@m.Puntos</td>
                </tr>
            }
        </tbody>
    </table>
}
<a href="@Url.Action("Index")" class="btn btn-secondary mt-3">⬅️ Volver</a>
