@model EcoReto.Models.Usuario
@{
    ViewBag.Title = "Eliminar Usuario";
}

<h2 class="text-center mb-4 text-danger">🗑️ Eliminar Usuario</h2>

<div class="card p-4 shadow-sm mx-auto text-center" style="max-width: 500px;">
    <h4>¿Estás seguro de eliminar al usuario <strong>@Model.UsuarioNombre</strong>?</h4>
    <p class="text-muted mt-2">Esta acción no se puede deshacer.</p>

    @using (Html.BeginForm("EliminarConfirmado", "Usuarios", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.IdUsuario)

        <button type="submit" class="btn btn-danger mt-3 w-100">Sí, eliminar</button>
        <a href="@Url.Action("Index")" class="btn btn-secondary w-100 mt-2">Cancelar</a>
    }
</div>
